---
interface Props {
  src: string;
  alt: string;
  caption: string;
  n: number;
}

const { src, alt, caption, n } = Astro.props;
const url = src.startsWith("/") ? src : `/figures/${src}`;
---
<figure class="essay-figure">
  <img src={url} alt={alt} loading="lazy" />
  <figcaption>
    <strong>Figure {n}.</strong> {caption}
  </figcaption>
</figure>

<style>
  .essay-figure {
    max-width: 600px;
    margin: 2rem auto;
  }
  .essay-figure img {
    width: 100%;
    height: auto;
    display: block;
  }
</style>
