---
import Base from "./Base.astro";

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  date: Date;
  summary: string;
  tier: string;
  readTime?: number;
  headings: Heading[];
  related?: string[];
}

const TIER_NAMES: Record<string, string> = {
  pipeline: "Core MuZero pipeline",
  wm: "World model training",
  planner: "Planner and Tinker",
  reward: "Reward and judging",
  retrieval: "Retrieval as ML",
  audits: "Audits and meta",
  infra: "Infrastructure",
};

const { title, date, summary, tier, readTime, headings, related = [] } = Astro.props;
const tierName = TIER_NAMES[tier] ?? tier;
const tocHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);

const dateStr = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---
<Base title={title} description={summary}>
  <header class="masthead">
    <a class="masthead-title" href="/">perseus essays</a>
    <span class="masthead-tier">{tierName}</span>
  </header>

  <div class="essay-grid">
    <aside class="rail">
      {tocHeadings.length > 0 && (
        <nav class="toc" aria-label="On this page">
          <div class="toc-label">On this page</div>
          <ul>
            {tocHeadings.map((h) => (
              <li class={`toc-d${h.depth}`}>
                <a href={`#${h.slug}`} data-toc-slug={h.slug}>{h.text}</a>
              </li>
            ))}
          </ul>
        </nav>
      )}

      {related.length > 0 && (
        <nav class="related" aria-label="Related essays">
          <div class="toc-label">Related</div>
          <ul>
            {related.map((slug) => (
              <li><a href={`/essays/${slug}/`}>{slug}</a></li>
            ))}
          </ul>
        </nav>
      )}
    </aside>

    <article class="reading">
      <h1>{title}</h1>
      <div class="meta">
        <time datetime={date.toISOString()}>{dateStr}</time>
        {readTime ? <span> &middot; {readTime} min read</span> : null}
      </div>
      <div class="prose">
        <slot />
      </div>
    </article>
  </div>

  <script is:inline>
    (function () {
      const links = Array.from(document.querySelectorAll("a[data-toc-slug]"));
      if (links.length === 0) return;
      const map = new Map();
      links.forEach((a) => map.set(a.getAttribute("data-toc-slug"), a));
      const targets = links
        .map((a) => document.getElementById(a.getAttribute("data-toc-slug")))
        .filter(Boolean);
      if (targets.length === 0) return;

      const setActive = (slug) => {
        links.forEach((a) => a.classList.remove("active"));
        const a = map.get(slug);
        if (a) a.classList.add("active");
      };

      const io = new IntersectionObserver(
        (entries) => {
          const visible = entries
            .filter((e) => e.isIntersecting)
            .sort((a, b) => a.target.getBoundingClientRect().top - b.target.getBoundingClientRect().top);
          if (visible.length > 0) setActive(visible[0].target.id);
        },
        { rootMargin: "-80px 0px -70% 0px", threshold: 0 },
      );
      targets.forEach((t) => io.observe(t));
    })();
  </script>
</Base>

<style>
  .masthead {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2rem 1.5rem 1.5rem;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    border-bottom: 1px solid var(--rule);
  }

  .masthead-title {
    font-family: var(--display);
    font-size: 22px;
    text-decoration: none;
    color: var(--text);
    letter-spacing: 0.02em;
  }

  .masthead-title:hover {
    color: var(--link-hov);
  }

  .masthead-tier {
    font-size: 13px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text-dim);
  }

  .essay-grid {
    max-width: 1100px;
    margin: 0 auto;
    padding: 3rem 1.5rem 5rem;
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 3rem;
    align-items: start;
  }

  .rail {
    position: sticky;
    top: 6rem;
    font-size: 13.5px;
    line-height: 1.5;
  }

  .toc-label {
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 12px;
    color: var(--text-faint);
    margin-bottom: 0.6rem;
  }

  .toc ul,
  .related ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .toc li,
  .related li {
    margin-bottom: 0.3em;
  }

  .toc .toc-d3 {
    padding-left: 1em;
  }

  .toc a,
  .related a {
    color: var(--text-dim);
    text-decoration: none;
  }

  .toc a:hover,
  .related a:hover {
    color: var(--link-hov);
  }

  .toc a.active {
    color: var(--text);
    font-weight: 700;
  }

  .related {
    margin-top: 2rem;
    border-top: 1px solid var(--rule);
    padding-top: 1.25rem;
  }

  .reading {
    max-width: var(--reading-max);
  }

  .reading .meta {
    margin-bottom: 2.5rem;
  }

  .prose :global(p) {
    margin: 0 0 1rem;
  }

  @media (max-width: 900px) {
    .essay-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
      padding: 2rem 1.25rem 4rem;
    }
    .rail {
      display: none;
    }
  }
</style>
